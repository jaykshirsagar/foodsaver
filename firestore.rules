rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid && request.resource.data.role in ['vanzator', 'utilizator'];
      allow read, update, delete: if signedIn() && request.auth.uid == uid;

      match /purchases/{listingId} {
        allow read, create, update, delete: if signedIn() && request.auth.uid == uid;
      }
    }

    match /listings/{listingId} {
      allow read: if signedIn();
      allow create: if signedIn() && userRole() in ['vanzator', 'admin', 'donor'] && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() && (
        userRole() == 'admin' || resource.data.ownerUid == request.auth.uid
      );
    }
  }
}
